
# Comma-separated list of domains this service will respond to.
# Required when ISDBENABLED=false.
SUPPORTED_DOMAINS=

# HTTP listen address (default: :8080)
LISTEN_ADDR=:8080

# --- Database (optional) ---
# Set ISDBENABLED=true to validate domains against a database.
ISDBENABLED=false
# Driver: mysql | mariadb | postgres
DBDRIVER=mysql
DBHOST=localhost
# Defaults: 3306 for mysql/mariadb, 5432 for postgres
DBPORT=
DBNAME=
DBUSER=
DBPASSW=
# SQL query to check domain existence. Must include a positional placeholder.
# MySQL/MariaDB: SELECT domain FROM domain WHERE domain = ?
# Postgres:      SELECT domain FROM domain WHERE domain = $1
QUERY_DOMAINS=

# --- Per-vendor template variable overrides ---
# Override any variable defined in a clientConfig's "vars" map.
# Format: TMPL_<VENDOR>_<KEY>=<value>  (VENDOR is uppercased)
# Examples:
# TMPL_MOZILLA_HOSTNAME=mail.example.com
# TMPL_MICROSOFT_HOSTNAME=mail.example.com
# TMPL_APPLE_HOSTNAME=mail.example.com
